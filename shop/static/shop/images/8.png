-modal');\\r\\n  const sportsLinks = document.querySelectorAll('a[href=\\\"#hbomax-sports-add-on-info-modal\\\"]');\\r\\n  const sportsModalCloseBtn = sportsModal.querySelector('.close');\\r\\n  let lastFocusedElement;\\r\\n\\r\\n  const handleEscKey = (e) =\u003e {\\r\\n    if (e.key === 'Escape' || e.key === 'Esc') {\\r\\n      e.preventDefault();\\r\\n      sportsModalCloseBtn.click();\\r\\n    }\\r\\n  };\\r\\n\\r\\n  const handleModalOpen = (e) =\u003e {\\r\\n    e.preventDefault();\\r\\n    lastFocusedElement = e.target;\\r\\n    document.body.classList.add('modal-open');\\r\\n    sportsModal.style.display = 'block';\\r\\n    sportsModal.classList.add('show');\\r\\n    sportsModal.focus();\\r\\n    document.addEventListener('keydown', handleEscKey);\\r\\n  }\\r\\n\\r\\n  const handleModalClose = (e) =\u003e {\\r\\n    document.body.classList.remove('modal-open');\\r\\n    document.removeEventListener('keydown', handleEscKey);\\r\\n    sportsModal.classList.remove('show');\\r\\n    sportsModal.style.display = 'none';\\r\\n    if (lastFocusedElement) {\\r\\n      lastFocusedElement.focus();\\r\\n      lastFocusedElement = '';\\r\\n    }\\r\\n  }\\r\\n\\r\\n  sportsLinks.forEach((el) =\u003e {\\r\\n    el.addEventListener('click', (e) =\u003e {\\r\\n      handleModalOpen(e);\\r\\n    });\\r\\n  });\\r\\n\\r\\n  sportsModalCloseBtn.addEventListener('click', (e) =\u003e {\\r\\n    handleModalClose(e);\\r\\n  });\\r\\n\\r\\n  window.addEventListener('click', (e) =\u003e {\\r\\n    if (e.target === sportsModal) {\\r\\n      handleModalClose(e);\\r\\n    }\\r\\n  });\\r\\n\\r\\n});\\r\\n\\r\\n\u003c/script\u003e\"},{\"componentID\":\"534183\",\"property\":\"code\",\"value\":\"\u003cstyle\u003e\\r\\n/**********************************************/\\r\\n/*                                            */\\r\\n/* Plan Picker v212 | Brand Refresh July 2025 */\\r\\n/*                                            */\\r\\n/* Sports Add-on Modal Window                 */\\r\\n/*                                            */\\r\\n/**********************************************/\\r\\n\\r\\n#hbomax-sports-add-on-info-modal {\\r\\n  background-color: rgba(0, 0, 0, 0.3);\\r\\n  backdrop-filter: blur(0.5em);\\r\\n}\\r\\n\\r\\n#hbomax-sports-add-on-info-modal .modal-header img {\\r\\n  border-top-left-radius: calc(.25rem - 1px);\\r\\n  border-top-right-radius: calc(.25rem - 1px);\\r\\n}\\r\\n\\r\\n#hbomax-sports-add-on-info-modal .modal-header img+.close {\\r\\n  margin: 0;\\r\\n  position: absolute;\\r\\n  right: 0;\\r\\n}\\r\\n\\r\\n#hbomax-sports-add-on-info-modal .modal-content {\\r\\n  container-type: inline-size;\\r\\n}\\r\\n\\r\\n#hbomax-sports-add-on-info-modal h3 {\\r\\n  font-size: 1.5rem;\\r\\n  margin: 0rem;\\r\\n}\\r\\n#hbomax-sports-add-on-info-modal p {\\r\\n  font-size: .9rem;\\r\\n  margin: 1rem 0rem;\\r\\n}\\r\\n#hbomax-sports-add-on-info-modal p.disclaimers {\\r\\n  line-height: .9rem;\\r\\n}\\r\\n#hbomax-sports-add-on-info-modal ul\u003eli\u003ep {\\r\\n  font-size: .9rem;\\r\\n  margin: 0rem;\\r\\n}\\r\\n#hbomax-sports-add-on-info-modal h4 {\\r\\n  font-size: 1.2rem;\\r\\n  margin-bottom: 1rem;\\r\\n}\\r\\n\\r\\n#hbomax-sports-add-on-info-modal .sports-logos-proportional {\\r\\n    --sports-logo-max-height: 50cqi;\\r\\n    display: flex;\\r\\n    gap: 2.5rem;\\r\\n    align-items: center;\\r\\n    justify-content: center;\\r\\n    margin: 1rem 0rem 0rem 0rem;\\r\\n    flex-wrap: wrap;\\r\\n}\\r\\n\\r\\n.sports-logos-proportional #sports-logo-1 {\\r\\n    height: calc(var(--sports-logo-max-height) * var(--sports-logo-1-scale) * var(--extra-resize));\\r\\n    width: auto;\\r\\n}\\r\\n.sports-logos-proportional #sports-logo-2 {\\r\\n    height: calc(var(--sports-logo-max-height) * var(--sports-logo-2-scale) * var(--extra-resize));\\r\\n    width: auto;\\r\\n}\\r\\n.sports-logos-proportional #sports-logo-3 {\\r\\n    height:calc(var(--sports-logo-max-height) * var(--sports-logo-3-scale) * var(--extra-resize));\\r\\n    width: auto;