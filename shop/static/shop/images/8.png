391\",\"property\":\"upcomingText\",\"value\":\"\"},{\"componentID\":\"599391\",\"property\":\"previous\",\"value\":\"\"},{\"componentID\":\"599391\",\"property\":\"ovTitle\",\"value\":\"[%DS4.data.globalContentLocalized.value.trending, $key=automation-exps%]\"},{\"componentID\":\"599391\",\"property\":\"next\",\"value\":\"\"},{\"componentID\":\"599391\",\"property\":\"moreUrl\",\"value\":\"\"},{\"componentID\":\"599391\",\"property\":\"moreText\",\"value\":\"\"},{\"componentID\":\"599391\",\"property\":\"liveText\",\"value\":\"\"},{\"componentID\":\"599391\",\"property\":\"collection\",\"value\":\"[%DS3.data.collection, $collectionId=13187%]\"},{\"componentID\":\"599391\",\"property\":\"castAndChar\",\"value\":\"\"},{\"componentID\":\"495387\",\"property\":\"imageUrlLink\",\"value\":\"\"},{\"componentID\":\"495387\",\"property\":\"imageCustomTitle\",\"value\":\"\"},{\"componentID\":\"495387\",\"property\":\"imageAltText\",\"value\":\"\"},{\"componentID\":\"599383\",\"property\":\"upcomingText\",\"value\":\"\"},{\"componentID\":\"599383\",\"property\":\"previous\",\"value\":\"\"},{\"componentID\":\"599383\",\"property\":\"ovTitle\",\"value\":\"[%DS4.data.globalContentLocalized.value.trending, $key=automation-exps%]\"},{\"componentID\":\"599383\",\"property\":\"next\",\"value\":\"\"},{\"componentID\":\"599383\",\"property\":\"moreUrl\",\"value\":\"\"},{\"componentID\":\"599383\",\"property\":\"moreText\",\"value\":\"\"},{\"componentID\":\"599383\",\"property\":\"liveText\",\"value\":\"\"},{\"componentID\":\"599383\",\"property\":\"collection\",\"value\":\"[%DS3.data.collection, $collectionId=13187%]\"},{\"componentID\":\"599383\",\"property\":\"castAndChar\",\"value\":\"\"},{\"componentID\":\"495387\",\"property\":\"imageUrlLink\",\"value\":\"\"},{\"componentID\":\"495387\",\"property\":\"imageCustomTitle\",\"value\":\"\"},{\"componentID\":\"495387\",\"property\":\"imageAltText\",\"value\":\"\"},{\"componentID\":\"574591\",\"property\":\"ymal\",\"value\":\"[%DS14.data.youMayAlsoLike.recommendationModel.items%]\"},{\"componentID\":\"574591\",\"property\":\"ltsYmal\",\"value\":\"[%DS4.data.globalContentLocalized.value.ymal, $key=stringstotranslate%]\"},{\"componentID\":\"599368\",\"property\":\"urlLinkAuth\",\"value\":\"[%DS4.data.globalContentLocalized.value.startstreamingctalink, $key=stringstotranslate%]\"},{\"componentID\":\"599368\",\"property\":\"urlLink\",\"value\":\"[%DS4.data.globalContentLocalized.value.signupctalink, $key=stringstotranslate%]\"},{\"componentID\":\"599368\",\"property\":\"labelAuth\",\"value\":\"[%DS4.data.globalContentLocalized.value.streamnowcta, $key=stringstotranslate%]\"},{\"componentID\":\"599368\",\"property\":\"label\",\"value\":\"[%DS4.data.globalContentLocalized.value.signupcta, $key=stringstotranslate%]\"},{\"componentID\":\"599368\",\"property\":\"flags\",\"value\":\"\"},{\"componentID\":\"599360\",\"property\":\"code\",\"value\":\"\u003cstyle\u003e\\r\\n    div[id*=\\\"Code\\\"] {\\r\\n        width: 100%;\\r\\n    }\\r\\n      article {\\r\\n        overflow: visible !important;\\r\\n      }\\r\\n      .secondary-nav-parent {\\r\\n        position: sticky;\\r\\n        top: 56px;\\r\\n        z-index: 1031;\\r\\n      }\\r\\n      .secondary-nav {\\r\\n        background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.7) 100%);\\r\\n      }\\r\\n      .secondary-nav .row {\\r\\n        margin: 0\\r\\n      }\\r\\n      .secondary-nav .col-md-12 .row {\\r\\n        background: rgba(0, 0, 0, 0.8);\\r\\n        margin: 0;\\r\\n        padding: 0;\\r\\n        border-radius: 8px;\\r\\n      }\\r\\n      .secondary-nav .col-md-12 .row::before {\\r\\n        position: absolute;\\r\\n        content: '';\\r\\n        width: 30px;\\r\\n        height: 100%;\\r\\n        background: linear-gradient(270deg, rgba(0, 0, 0, 0.8) 40%, rgba(0, 0, 0, 0));\\r\\n        z-index: 3;\\r\\n        right: 15px;\\r\\n        border-radius: 8px;\\r\\n      }\\r\\n      .secondary-nav .col-md-12 .row::after {\\r\\n        position: absolute;\\r\\n        content: '';\\r\\n        width: 30px;\\r\\n        height: 100%;\\r\\n        background: linear-gradient(270deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.8) 40%);\\r\\n        z-index: 3;\\r\\n        left: 14px;\\r\\n        border-radius: 8px;\\r\\n      }\\r\\n      .secondary-nav .tabs {\\r\\n        position: relative;\\r\\n        width: auto;\\r\\n        margin: 0 auto;\\r\\n        display: flex;\\r\\n        flex-wrap: nowrap;\\r\\n        overflow-x: scroll;\\r\\n        scroll-behavior: smooth;\\r\\n        justify-content: flex-start;\\r\\n      }\\r\\n      .secondary-nav .tabs::-webkit-scrollbar {\\r\\n        display: none;\\r\\n      }\\r\\n      .secondary-nav .tab {\\r\\n        color: #fff;\\r\\n        background: none;\\r\\n        border-radius: 0;\\r\\n        border: none;\\r\\n        font-weight: 700;\\r\\n        font-size: 0.875rem;\\r\\n        text-transform: uppercase;\\r\\n        letter-spacing: 0;\\r\\n        padding: 0.75rem 1.5rem;\\r\\n        position: relative;\\r\\n        z-index: 2;\\r\\n        display: flex;\\r\\n        align-items: center;\\r\\n        justify-content: center;\\r\\n        margin: 0;\\r\\n        line-height: 1;\\r\\n        cursor: pointer;\\r\\n        white-space: nowrap;\\r\\n      }\\r\\n      .secondary-nav .tab:hover {\\r\\n        text-decoration: underline;\\r\\n      }\\r\\n      .secondary-nav .arrows {\\r\\n        position: absolute;\\r\\n        bottom: 0;\\r\\n        width: calc(100% - 30px);\\r\\n        height: 100%;\\r\\n        margin: 0 auto;\\r\\n        left: 15px;\\r\\n      }\\r\\n      .secondary-nav .prev,\\r\\n      .secondary-nav .next {\\r\\n        position: absolute;\\r\\n        z-index: 4;\\r\\n        opacity: 0;\\r\\n        transition: all 0.2s ease-out;\\r\\n      }\\r\\n      .secondary-nav .prev {\\r\\n        left: 5px;\\r\\n        bottom: 3px;\\r\\n        transform: rotate(180deg);\\r\\n      }\\r\\n      .secondary-nav .next {\\r\\n        right: 5px;\\r\\n        bottom: 6px;\\r\\n      }\\r\\n      .secondary-nav .prev svg,\\r\\n      .secondary-nav .next svg {\\r\\n        z-index: 1;\\r\\n        height: 20px;\\r\\n      }\\r\\n      .secondary-nav-sign-up-cta-parent.visible .secondary-nav-sign-up-cta {\\r\\n        transform: translateY(0);\\r\\n        opacity: 1;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      .secondary-nav-sign-up-cta {\\r\\n        position: fixed;\\r\\n        bottom: 0;\\r\\n        z-index: 3;\\r\\n        background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, #000 100%);\\r\\n        transform: translateY(100%);\\r\\n        opacity: 0;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      nav.header div {\\r\\n        transform: translateY(0);\\r\\n        opacity: 1;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      nav.header.hidden div {\\r\\n        transform: translateY(-100%);\\r\\n        opacity: 0;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      @media (min-width: 992px) {\\r\\n        .secondary-nav .col-md-12 .row {\\r\\n          background: none;\\r\\n        }\\r\\n        .secondary-nav .col-md-12 .row::before,\\r\\n        .secondary-nav .col-md-12 .row::after {\\r\\n          display: none;\\r\\n        }\\r\\n        .secondary-nav .tabs {\\r\\n          background: rgba(0, 0, 0, 0.8);\\r\\n          border-radius: 8px;\\r\\n        }\\r\\n      }\\r\\n      @media (max-width: 575px) {\\r\\n        .secondary-nav-parent {\\r\\n          top: 54px;\\r\\n        }\\r\\n      }\\r\\n    \u003c/style\u003e\\r\\n\\r\\n\u003cdiv class=\\\"row\\\"\u003e\\r\\n    \u003cdiv class=\\\"tabs\\\"\u003e\\r\\n            \u003cbutton class=\\\"tab tab-ymal\\\"\u003e[%DS4.data.globalContentLocalized.value.ymal, $key=stringstotranslate%]\u003c/button\u003e\\r\\n        \u003cbutton class=\\\"tab tab-trending\\\"\u003e[%DS4.data.globalContentLocalized.value.trending, $key=automation-exps%]\u003c/button\u003e\\r\\n        \u003cbutton class=\\\"tab tab-production-credits\\\"\u003e[%DS4.data.globalContentLocalized.value.titlepage-aboutmovie, $key=stringstotranslate%]\u003c/button\u003e\\r\\n    \u003c/div\u003e\\r\\n    \u003cdiv class=\\\"arrows\\\"\u003e\\r\\n            \u003cdiv class=\\\"next\\\"\u003e\\r\\n              \u003csvg width=\\\"14\\\" height=\\\"26\\\" viewBox=\\\"0 0 14 26\\\" fill=\\\"none\\\"\u003e\\r\\n                \u003cpath d=\\\"M1.5 24.5L12.5 13L1.5 1.5\\\" stroke=\\\"white\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"\u003e\u003c/path\u003e\\r\\n              \u003c/svg\u003e\\r\\n            \u003c/div\u003e\\r\\n            \u003cdiv class=\\\"prev\\\"\u003e\\r\\n              \u003csvg width=\\\"14\\\" height=\\\"26\\\" viewBox=\\\"0 0 14 26\\\" fill=\\\"none\\\"\u003e\\r\\n                \u003cpath d=\\\"M1.5 24.5L12.5 13L1.5 1.5\\\" stroke=\\\"white\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"\u003e\u003c/path\u003e\\r\\n              \u003c/svg\u003e\\r\\n            \u003c/div\u003e\\r\\n          \u003c/div\u003e\\r\\n\u003c/div\u003e\\r\\n\\r\\n\u003cscript\u003e\\r\\n      document.addEventListener('DOMContentLoaded', function () {\\r\\n        const offset = 100; // Offset in pixels\\r\\n\\r\\n        const secondaryNavs = document.querySelectorAll('.secondary-nav-parent');\\r\\n\\r\\n        secondaryNavs.forEach((nav) =\u003e {\\r\\n          if (nav.classList.contains('hide')) return;\\r\\n\\r\\n          const scrollMappings = [\\r\\n            { trigger: '.tab-ymal', target: '.max-section-ymal-parent' },\\r\\n            { trigger: '.tab-trending', target: '.max-section-trending-parent' },\\r\\n            { trigger: '.tab-production-credits', target: '.max-section-production-credits' },\\r\\n            { trigger: '.tab-plan', target: '.max-section-plan-picker' },\\r\\n          ];\\r\\n\\r\\n         \\r\\n          // Scrolling Behavior when secondary nav is clicked\\r\\n          scrollMappings.forEach((mapping) =\u003e {\\r\\n            const scrollTrigger = nav.querySelector(mapping.trigger);\\r\\n            const targetSection = Array.from(document.querySelectorAll(mapping.target)).find((el) =\u003e !el.classList.contains('hide'));\\r\\n\\r\\n            //   if Trigger and Target both exist\\r\\n            if (scrollTrigger \u0026\u0026 targetSection) {\\r\\n              scrollTrigger.addEventListener('click', function (event) {\\r\\n                event.preventDefault();\\r\\n\\r\\n                const elementPosition = targetSection.getBoundingClientRect().top + window.pageYOffset;\\r\\n                const offsetPosition = elementPosition - offset;\\r\\n\\r\\n                window.scrollTo({\\r\\n                  top: offsetPosition,\\r\\n                  behavior: 'smooth',\\r\\n                });\\r\\n              });\\r\\n            }\\r\\n          });\\r\\n          \\r\\n          // Horizontal scrollable navs\\r\\n          const tabsContainer = nav.querySelector('.secondary-nav .tabs');\\r\\n          const prevArrow = nav.querySelector('.arrows .prev');\\r\\n          const nextArrow = nav.querySelector('.arrows .next');\\r\\n\\r\\n          const opacityHide = (item) =\u003e (item.style.opacity = '0');\\r\\n          const opacityShow = (item) =\u003e (item.style.opacity = '1');\\r\\n\\r\\n          const updateArrows = () =\u003e {\\r\\n            const maxScroll = tabsContainer.scrollWidth - tabsContainer.clientWidth;\\r\\n            const currentScroll = tabsContainer.scrollLeft;\\r\\n            const percent = (currentScroll / maxScroll) * 100;\\r\\n\\r\\n            if (!maxScroll) {\\r\\n              opacityHide(nextArrow);\\r\\n              opacityHide(prevArrow);\\r\\n              return;\\r\\n            }\\r\\n\\r\\n            if (percent \u003e= 99) {\\r\\n              opacityHide(nextArrow);\\r\\n              opacityShow(prevArrow);\\r\\n            } else if (percent \u003c= 1) {\\r\\n              opacityShow(nextArrow);\\r\\n              opacityHide(prevArrow);\\r\\n            } else {\\r\\n              opacityHide(nextArrow);\\r\\n              opacityHide(prevArrow);\\r\\n            }\\r\\n          };\\r\\n\\r\\n          new ResizeObserver(updateArrows).observe(tabsContainer);\\r\\n\\r\\n          nextArrow.addEventListener('click', () =\u003e {\\r\\n            tabsContainer.scrollLeft = tabsContainer.scrollWidth - tabsContainer.clientWidth;\\r\\n            updateArrows();\\r\\n          });\\r\\n\\r\\n          prevArrow.addEventListener('click', () =\u003e {\\r\\n            tabsContainer.scrollLeft = 0;\\r\\n            updateArrows();\\r\\n          });\\r\\n\\r\\n          tabsContainer.addEventListener('scroll', updateArrows);\\r\\n        });\\r\\n\\r\\n        // Once hero section is passed and secondary nav is sticky\\r\\n         document.addEventListener('scroll', function () {\\r\\n          const signupBtns = document.querySelectorAll('.secondary-nav-sign-up-cta-parent');\\r\\n          const headerNav = document.querySelector('nav.header');\\r\\n          const scrollNav = Array.from(document.querySelectorAll('.secondary-nav-parent')).find((el) =\u003e !el.classList.contains('hide'));\\r\\n\\r\\n          const scrollPosition = window.scrollY || window.pageYOffset;\\r\\n          const navStickyPos = window.innerHeight * 0.9;\\r\\n\\r\\n          // Add hidden class to main header nav\\r\\n          if (window.innerWidth \u003e 1024 \u0026\u0026 scrollNav \u0026\u0026 scrollPosition \u003e navStickyPos) {\\r\\n            headerNav.classList.add('hidden');\\r\\n          } else if (scrollNav \u0026\u0026 scrollPosition \u003e window.innerHeight) {\\r\\n            headerNav.classList.add('hidden');\\r\\n          } else {\\r\\n            headerNav.classList.remove('hidden');\\r\\n          }\\r\\n\\r\\n          // Add visible class to sign up cta\\r\\n          signupBtns.forEach((btn) =\u003e {\\r\\n            if (window.innerWidth \u003e 1024 \u0026\u0026 !btn.classList.contains('hide') \u0026\u0026 scrollPosition \u003e navStickyPos) {\\r\\n              btn.classList.add('visible');\\r\\n            } else if (!btn.classList.contains('hide') \u0026\u0026 scrollPosition \u003e window.innerHeight) {\\r\\n              btn.classList.add('visible');\\r\\n            } else {\\r\\n              btn.classList.remove('visible');\\r\\n            }\\r\\n          });\\r\\n        });\\r\\n      });\\r\\n    \u003c/script\u003e\"},{\"componentID\":\"599352\",\"property\":\"urlLinkAuth\",\"value\":\"[%DS4.data.globalContentLocalized.value.startstreamingctalink, $key=stringstotranslate%]\"},{\"componentID\":\"599352\",\"property\":\"urlLink\",\"value\":\"[%DS4.data.globalContentLocalized.value.signupctalink, $key=stringstotranslate%]\"},{\"componentID\":\"599352\",\"property\":\"labelAuth\",\"value\":\"[%DS4.data.globalContentLocalized.value.streamnowcta, $key=stringstotranslate%]\"},{\"componentID\":\"599352\",\"property\":\"label\",\"value\":\"[%DS4.data.globalContentLocalized.value.signupcta, $key=stringstotranslate%]\"},{\"componentID\":\"599352\",\"property\":\"flags\",\"value\":\"\"},{\"componentID\":\"599344\",\"property\":\"code\",\"value\":\"\u003cstyle\u003e\\r\\n    div[id*=\\\"Code\\\"] {\\r\\n        width: 100%;\\r\\n    }\\r\\n      article {\\r\\n        overflow: visible !important;\\r\\n      }\\r\\n      .secondary-nav-parent {\\r\\n        position: sticky;\\r\\n        top: 56px;\\r\\n        z-index: 1031;\\r\\n      }\\r\\n      .secondary-nav {\\r\\n        background: linear-gradient(0deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.7) 100%);\\r\\n      }\\r\\n      .secondary-nav .row {\\r\\n        margin: 0\\r\\n      }\\r\\n      .secondary-nav .col-md-12 .row {\\r\\n        background: rgba(0, 0, 0, 0.8);\\r\\n        margin: 0;\\r\\n        padding: 0;\\r\\n        border-radius: 8px;\\r\\n      }\\r\\n      .secondary-nav .col-md-12 .row::before {\\r\\n        position: absolute;\\r\\n        content: '';\\r\\n        width: 30px;\\r\\n        height: 100%;\\r\\n        background: linear-gradient(270deg, rgba(0, 0, 0, 0.8) 40%, rgba(0, 0, 0, 0));\\r\\n        z-index: 3;\\r\\n        right: 15px;\\r\\n        border-radius: 8px;\\r\\n      }\\r\\n      .secondary-nav .col-md-12 .row::after {\\r\\n        position: absolute;\\r\\n        content: '';\\r\\n        width: 30px;\\r\\n        height: 100%;\\r\\n        background: linear-gradient(270deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.8) 40%);\\r\\n        z-index: 3;\\r\\n        left: 14px;\\r\\n        border-radius: 8px;\\r\\n      }\\r\\n      .secondary-nav .tabs {\\r\\n        position: relative;\\r\\n        width: auto;\\r\\n        margin: 0 auto;\\r\\n        display: flex;\\r\\n        flex-wrap: nowrap;\\r\\n        overflow-x: scroll;\\r\\n        scroll-behavior: smooth;\\r\\n        justify-content: flex-start;\\r\\n      }\\r\\n      .secondary-nav .tabs::-webkit-scrollbar {\\r\\n        display: none;\\r\\n      }\\r\\n      .secondary-nav .tab {\\r\\n        color: #fff;\\r\\n        background: none;\\r\\n        border-radius: 0;\\r\\n        border: none;\\r\\n        font-weight: 700;\\r\\n        font-size: 0.875rem;\\r\\n        text-transform: uppercase;\\r\\n        letter-spacing: 0;\\r\\n        padding: 0.75rem 1.5rem;\\r\\n        position: relative;\\r\\n        z-index: 2;\\r\\n        display: flex;\\r\\n        align-items: center;\\r\\n        justify-content: center;\\r\\n        margin: 0;\\r\\n        line-height: 1;\\r\\n        cursor: pointer;\\r\\n        white-space: nowrap;\\r\\n      }\\r\\n      .secondary-nav .tab:hover {\\r\\n        text-decoration: underline;\\r\\n      }\\r\\n      .secondary-nav .arrows {\\r\\n        position: absolute;\\r\\n        bottom: 0;\\r\\n        width: calc(100% - 30px);\\r\\n        height: 100%;\\r\\n        margin: 0 auto;\\r\\n        left: 15px;\\r\\n      }\\r\\n      .secondary-nav .prev,\\r\\n      .secondary-nav .next {\\r\\n        position: absolute;\\r\\n        z-index: 4;\\r\\n        opacity: 0;\\r\\n        transition: all 0.2s ease-out;\\r\\n      }\\r\\n      .secondary-nav .prev {\\r\\n        left: 5px;\\r\\n        bottom: 3px;\\r\\n        transform: rotate(180deg);\\r\\n      }\\r\\n      .secondary-nav .next {\\r\\n        right: 5px;\\r\\n        bottom: 6px;\\r\\n      }\\r\\n      .secondary-nav .prev svg,\\r\\n      .secondary-nav .next svg {\\r\\n        z-index: 1;\\r\\n        height: 20px;\\r\\n      }\\r\\n      .secondary-nav-sign-up-cta-parent.visible .secondary-nav-sign-up-cta {\\r\\n        transform: translateY(0);\\r\\n        opacity: 1;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      .secondary-nav-sign-up-cta {\\r\\n        position: fixed;\\r\\n        bottom: 0;\\r\\n        z-index: 3;\\r\\n        background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, #000 100%);\\r\\n        transform: translateY(100%);\\r\\n        opacity: 0;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      nav.header div {\\r\\n        transform: translateY(0);\\r\\n        opacity: 1;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      nav.header.hidden div {\\r\\n        transform: translateY(-100%);\\r\\n        opacity: 0;\\r\\n        transition: all 0.5s ease-out;\\r\\n      }\\r\\n      @media (min-width: 992px) {\\r\\n        .secondary-nav .col-md-12 .row {\\r\\n          background: none;\\r\\n        }\\r\\n        .secondary-nav .col-md-12 .row::before,\\r\\n        .secondary-nav .col-md-12 .row::after {\\r\\n          display: none;\\r\\n        }\\r\\n        .secondary-nav .tabs {\\r\\n          background: rgba(0, 0, 0, 0.8);\\r\\n          border-radius: 8px;\\r\\n        }\\r\\n      }\\r\\n      @media (max-width: 575px) {\\r\\n        .secondary-nav-parent {\\r\\n          top: 54px;\\r\\n        }\\r\\n      }\\r\\n    \u003c/style\u003e\\r\\n\\r\\n\u003cdiv class=\\\"row\\\"\u003e\\r\\n    \u003cdiv class=\\\"tabs\\\"\u003e\\r\\n        \u003cbutton class=\\\"tab tab-ymal\\\"\u003e[%DS4.data.globalContentLocalized.value.ymal, $key=stringstotranslate%]\u003c/button\u003e\\r\\n        \u003cbutton class=\\\"tab tab-production-credits\\\"\u003e[%DS4.data.globalContentLocalized.value.titlepage-aboutmovie, $key=stringstotranslate%]\u003c/button\u003e\\r\\n    \u003c/div\u003e\\r\\n    \u003cdiv class=\\\"arrows\\\"\u003e\\r\\n            \u003cdiv class=\\\"next\\\"\u003e\\r\\n              \u003csvg width=\\\"14\\\" height=\\\"26\\\" viewBox=\\\"0 0 14 26\\\" fill=\\\"none\\\"\u003e\\r\\n                \u003cpath d=\\\"M1.5 24.5L12.5 13L1.5 1.5\\\" stroke=\\\"white\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"\u003e\u003c/path\u003e\\r\\n              \u003c/svg\u003e\\r\\n            \u003c/div\u003e\\r\\n            \u003cdiv class=\\\"prev\\\"\u003e\\r\\n              \u003csvg width=\\\"14\\\" height=\\\"26\\\" viewBox=\\\"0 0 14 26\\\" fill=\\\"none\\\"\u003e\\r\\n                \u003cpath d=\\\"M1.5 24.5L12.5 13L1.5 1.5\\\" stroke=\\\"white\\\" stroke-width=\\\"2\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"\u003e\u003c/path\u003e\\r\\n              \u003c/svg\u003e\\r\\n            \u003c/div\u003e\\r\\n          \u003c/div\u003e\\r\\n\u003c/div\u003e\\r\\n\\r\\n\u003cscript\u003e\\r\\n      document.addEventListener('DOMContentLoaded', function () {\\r\\n        const offset = 100; // Offset in pixels\\r\\n\\r\\n        const secondaryNavs = document.querySelectorAll('.secondary-nav-parent');\\r\\n\\r\\n        secondaryNavs.forEach((nav) =\u003e {\\r\\n          if (nav.classList.contains('hide')) return;\\r\\n\\r\\n          const scrollMappings = [\\r\\n            { trigger: '.tab-ymal', target: '.max-section-ymal-parent' },\\r\\n            { trigger: '.tab-trending', target: '.max-section-trending-parent' },\\r\\n            { trigger: '.tab-production-credits', target: '.max-section-production-credits' },\\r\\n            { trigger: '.tab-plan', target: '.max-section-plan-picker' },\\r\\n          ];\\r\\n\\r\\n         \\r\\n          // Scrolling Behavior when secondary nav is clicked\\r\\n          scrollMappings.forEach((mapping) =\u003e {\\r\\n            const scrollTrigger = nav.querySelector(mapping.trigger);\\r\\n            const targetSection = Array.from(document.querySelectorAll(mapping.target)).find((el) =\u003e !el.classList.contains('hide'));\\r\\n\\r\\n            //   if Trigger and Target both exist\\r\\n            if (scrollTrigger \u0026\u0026 targetSection) {\\r\\n              scrollTrigger.addEventListener('click', function (event) {\\r\\n                event.preventDefault();\\r\\n\\r\\n                const elementPosition = targetSection.getBoundingClientRect().top + window.pageYOffset;\\r\\n                const offsetPosition = elementPosition - offset;\\r\\n\\r\\n                window.scrollTo({\\r\\n                  top: offsetPosition,\\r\\n                  behavior: 'smooth',\\r\\n                });\\r\\n              });\\r\\n            }\\r\\n          });\\r\\n          // Horizontal scrollable navs\\r\\n          const tabsContainer = nav.querySelector('.secondary-nav .tabs');\\r\\n          const prevArrow = nav.querySelector('.arrows .prev');\\r\\n          const nextArrow = nav.querySelector('.arrows .next');\\r\\n\\r\\n          const opacityHide = (item) =\u003e (item.style.opacity = '0');\\r\\n          const opacityShow = (item) =\u003e (item.style.opacity = '1');\\r\\n\\r\\n          const updateArrows = () =\u003e {\\r\\n            const maxScroll = tabsContainer.scrollWidth - tabsContainer.clientWidth;\\r\\n            const currentScroll = tabsContainer.scrollLeft;\\r\\n            const percent = (currentScroll / maxScroll) * 100;\\r\\n\\r\\n            if (!maxScroll) {\\r\\n              opacityHide(nextArrow);\\r\\n              opacityHide(prevArrow);\\r\\n              return;\\r\\n            }\\r\\n\\r\\n            if (percent \u003e= 99) {\\r\\n              opacityHide(nextArrow);\\r\\n              opacityShow(prevArrow);\\r\\n            } else if (percent \u003c= 1) {\\r\\n              opacityShow(nextArrow);\\r\\n              opacityHide(prevArrow);\\r\\n            } else {\\r\\n              opacityHide(nextArrow);\\r\\n              opacityHide(prevArrow);\\r\\n            }\\r\\n          };\\r\\n\\r\\n          new ResizeObserver(updateArrows).observe(tabsContainer);\\r\\n\\r\\n          nextArrow.addEventListener('click', () =\u003e {\\r\\n            tabsContainer.scrollLeft = tabsContainer.scrollWidth - tabsContainer.clientWidth;\\r\\n            updateArrows();\\r\\n          });\\r\\n\\r\\n          prevArrow.addEventListener('click', () =\u003e {\\r\\n            tabsContainer.scrollLeft = 0;\\r\\n            updateArrows();\\r\\n          });\\r\\n\\r\\n          tabsContainer.addEventListener('scroll', updateArrows);\\r\\n        });\\r\\n\\r\\n         // Once hero section is passed and secondary nav is sticky\\r\\n         document.addEventListener('scroll', function () {\\r\\n          const signupBtns = document.querySelectorAll('.secondary-nav-sign-up-cta-parent');\\r\\n          const headerNav = document.querySelector('nav.header');\\r\\n          const scrollNav = Array.from(document.querySelectorAll('.secondary-nav-parent')).find((el) =\u003e !el.classList.contains('hide'));\\r\\n\\r\\n          const scrollPosition = window.scrollY || window.pageYOffset;\\r\\n          const navStickyPos = window.innerHeight * 0.9;\\r\\n\\r\\n          // Add hidden class to main header nav\\r\\n          if (window.innerWidth \u003e 1024 \u0026\u0026 scrollNav \u0026\u0026 scrollPosition \u003e navStickyPos) {\\r\\n            headerNav.classList.add('hidden');\\r\\n          } else if (scrollNav \u0026\u0026 scrollPosition \u003e window.innerHeight) {\\r\\n            headerNav.classList.add('hidden');\\r\\n          } else {\\r\\n            headerNav.classList.remove('hidden');\\r\\n          }\\r\\n\\r\\n          // Add visible class to sign up cta\\r\\n          signupBtns.forEach((btn) =\u003e {\\r\\n            if (window.innerWidth \u003e 1024 \u0026\u0026 !btn.classList.contains('hide') \u0026\u0026 scrollPosition \u003e navStickyPos) {\\r\\n              btn.classList.add('visible');\\r\\n            } else if (!btn.classList.contains('hide') \u0026\u0026 scrollPosition \u003e window.innerHeight) {\\r\\n              btn.classList.add('visible');\\r\\n            } else {\\r\\n              btn.classList.remove('visible');\\r\\n            }\\r\\n          });\\r\\n        });\\r\\n      });\\r\\n    \u003c/script\u003e\"},{\"componentID\":\"534109\",\"property\":\"urlLinkAuth\",\"value\":\"[%DS4.data.globalContentLocalized.value.startstreamingctalink, $key=stringstotranslate%]\"},{\"componentID\":\"534109\",\"property\":\"urlLink\",\"value\":\"/\"},{\"componentID\":\"534109\",\"property\":\"labelAuth\",\"value\":\"[%DS4.data.globalContentLocalized.value.streamnowcta, $key=stringstotranslate%]\"},{\"componentID\":\"534109\",\"property\":\"label\",\"value\":\"[%DS4.data.globalContentLocalized.value.home, $key=stringstotranslate%]\"},{\"componentID\":\"534108\",\"property\":\"text\",\"value\":\"\u003ch1 class=\\\"text-left\\\"\u003e\u003cstrong\u003e[%DS2.data.feature.title.full%]\u003c/strong\u003e\u003c/h1\u003e\u003cp class=\\\"text-left\\\"\u003e: [%DS2.data.feature.summary.short%]\u003c/p\u003e\"},{\"componentID\":\"534108\",\"property\":\"ltsMore\",\"value\":\"\"},{\"componentID\":\"534108\",\"property\":\"ltsLess\",\"value\":\"\"},{\"componentID\":\"534107\",\"property\":\"text\",\"value\":\"\u003ch6 class=\\\"text-left\\\"\u003e[%DS2.data.feature.localizedRating.classifier%]\u0026nbsp;\u003c/h6\u003e\u003ch6 class=\\\"text-left\\\"\u003e[%DS2.data.feature.releas