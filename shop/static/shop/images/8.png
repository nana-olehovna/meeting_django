partners-google', 'onetrustbot', 'se 2.x metasr 1.0', 'storebot-google', 'twitterbot', 'y!j-srd', 'yahoo! slurp', 'yowser'];\n  // Global pages that should not be redirected (including subpages)\n  const GLOBAL_PAGES = ['/geo-availability', '/privacy', '/terms-of-use'];\n  // Duplicate of COOKIE_NAMES from constants/cookies.ts.\n  // We'll use this to avoid importing the constants file, because we can't use imports when babel transforming this function into a string.\n  const COOKIE_NAMES = {\n    SELECTED_LANGUAGE: 'selectedLanguage',\n    USER_ON_PREFERRED_URL: 'userOnPreferredUrl'\n  };\n  // Instead of using js-cookie, we'll use the document.cookie API to set the cookie value.\n  // This is because we can't use imports when babel transforming this function into a string.\n  const setCookie = (name, value) =\u003e {\n    document.cookie = `${name}=${value}; path=/`;\n  };\n  // Instead of using js-cookie, we'll use the document.cookie API to get the cookie value.\n  // This is because we can't use imports when babel transforming this function into a string.\n  const getCookie = name =\u003e {\n    const cookies = `; ${document.cookie}`;\n    const cookieParts = cookies.split(`; ${name}=`);\n    if (cookieParts.length === 2) {\n      // Extract value before the next semicolon (or end of string)\n      return cookieParts[1].split(';')[0];\n    }\n    return undefined;\n  };\n  const isBot = userAgent =\u003e {\n    const lowerUserAgent = userAgent.toLowerCase();\n    return BOT_USER_AGENTS.some(bot =\u003e lowerUserAgent.includes(bot.toLowerCase()));\n  };\n  const isGlobalPage = url =\u003e GLOBAL_PAGES.some(page =\u003e url.includes(page));\n  // --------------------------------------------------------------------------------\n  // TODO: This is a copy of the function in handleLocalizationRefresh.ts. We should refactor this to avoid duplication.\n  // We'll need to remove this header injection logic and probably use middleware or proxy to handle this.\n  // We'll also need Bolt to be implemented on the server side to handle this.\n  const getLanguagePath = (languageBcp47Code, userCountry, countryLangUris, countryMappings) =\u003e {\n    if (!languageBcp47Code || !countryMappings || !countryLangUris || !userCountry) {\n      const missingParams = [];\n      if (!languageBcp47Code) {\n        missingParams.push('languageBcp47Code');\n      }\n      if (!countryMappings) {\n        missingParams.push('countryMappings');\n      }\n      if (!countryLangUris) {\n        missingParams.push('countryLangUris');\n      }\n      if (!userCountry) {\n        missingParams.push('userCountry');\n      }\n      console.error(`Cannot get language path: missing required parameters. Missing: ${missingParams.join(', ')}`);\n      return;\n    }\n    // We can only redirect to the user's country, so we first check the userCountry and then the languageBcp47Code\n    const countryMapping = countryMappings.find(mapping =\u003e mapping.countryCode === userCountry.toLowerCase() \u0026\u0026 mapping.bcp47Code === languageBcp47Code);\n    // No redirect if the country mapping is not found\n    if (!countryMapping) {\n      return;\n    }\n    const {\n      countryCode,\n      language\n    } = countryMapping;\n    const countryLanguageKey = `${countryCode}/${language}`;\n    const countryLanguageUri = countryLangUris[countryLanguageKey];\n    // No matching pair or language found\n    if (!countryLanguageUri || !language) {\n      return;\n    }\n    const {\n      url: countryLanguagePath,\n      startDate,\n      endDate\n    } = countryLanguageUri;\n    // Check if content is within availability window\n    const isPageAvailable = (() =\u003e {\n      // If startDate and endDate are falsy, the page is always available\n      if (!startDate \u0026\u0026 !endDate) {\n        return true;\n      }\n      const currDate = Date.now();\n      const start = startDate ? Date.parse(startDate) : 0;\n      const end = endDate ? Date.parse(endDate) : Infinity;\n      // Validate parsed dates - if parsing fails, treat as unavailable\n      if (Number.isNaN(start) || Number.isNaN(end)) {\n        console.warn(`Invalid date format in countryLangUri: startDate=\"${startDate}\", endDate=\"${endDate}\"`);\n        return false;\n      }\n      // If the current date is between start and end, the page is available\n      return start \u003c= currDate \u0026\u0026 currDate \u003c= end;\n    })();\n    // No redirect if content is not available\n    if (!isPageAvailable) {\n      return;\n    }\n    // Remove country/lang prefix for US English (e.g., /us/en/home -\u003e /home)\n    if (countryCode === 'us' \u0026\u0026 language === 'en') {\n      const prefix = `/${countryLanguageKey}`;\n      if (countryLanguagePath.startsWith(prefix)) {\n        return countryLanguagePath.slice(prefix.length) || '/';\n      }\n    }\n    return countryLanguagePath;\n  };\n  // --------------------------------------------------------------------------------\n  // Don't redirect bots or global pages\n  if (isBot(globalThis.navigator.userAgent) || isGlobalPage(globalThis.location.pathname)) {\n    return;\n  }\n  // --------------------------------------------------------------------------------\n  // TODO: This is a copy of the logic in handleLocalizationRefresh.ts. We should refactor this to avoid duplication.\n  // We'll need to remove this header injection logic and probably use middleware or proxy to handle this.\n  // We'll also need Bolt to be implemented on the server side to handle this.\n  // Redirect to preferred language URL if user selected language from language selector and content is available in that language\n  const preferredLanguageBcp47Code = getCookie(COOKIE_NAMES.SELECTED_LANGUAGE);\n  const preferredLanguagePath = getLanguagePath(preferredLanguageBcp47Code !== null \u0026\u0026 preferredLanguageBcp47Code !== void 0 ? preferredLanguageBcp47Code : '', userCountry, countryLangUris, countryMappings);\n  // If the preferred language path is different from the current path, redirect to the preferred language path\n  if (preferredLanguagePath \u0026\u0026 preferredLanguagePath !== globalThis.location.pathname) {\n    setCookie(COOKIE_NAMES.USER_ON_PREFERRED_URL, 'true');\n    globalThis.location.href = `${globalThis.location.origin}${preferredLanguagePath}${globalThis.location.search}`;\n    return;\n  }\n  // --------------------------------------------------------------------------------\n  // Redirect to geo-specific URL if user is in region\n  if (geoRedirectUrl \u0026\u0026 !isUserOutOfRegion) {\n    // Remove trailing slash to avoid another redirect\n    const normalizedRedirectPath = geoRedirectUrl.replace(/\\/$/, '') || '/';\n    globalThis.location.href = `${globalThis.location.origin}${normalizedRedirectPath}${globalThis.location.search}`;\n    return;\n  }\n}","geoRedirectUrl":"","globalDomain":"api.hbomax.com","nextGlobalDomain":null,"hostnameToOverride":null,"isCMSErrorPage":false,"isEventPage":false,"isPreviewServer":false,"isSeasonPage":false,"isUserOutOfRegion":true,"isVideoWatchPage":false,"labsSDKVersion":"2.4.2","labsTrackUrl":"https://prd.api.discomax.com/labs/api/v1/decision/track","languageVariables":{"lang":"en","country":"gb","region":"emea"},"logoPath":"/img/hbomax/logo_nav_bar.png","mappedData":{"idref0":"Watch Rocknrolla | HBO Max","idref1":"video.movie","idref2":"https://beam-images.warnermediacdn.com/BEAM_LWM_DELIVERABLES/ca822895-cfb2-4fd7-a1bc-3ba5ddf3549c/e61cbad265f1720051c07f2f6ab6709da6a933d8.jpg?submitted=1684671188405\u0026host=wbd-images.prod-vod.h264.io\u0026partner=beamcom\u0026w=500","idref3":"640","idref4":"320","idref5":"Rocknrolla","idref6":"2008","idref7":"https://beam-images.warnermediacdn.com/BEAM_LWM_DELIVERABLES/ca822895-cfb2-4fd7-a1bc-3ba5ddf3549c/e61cbad265f1720051c07f2f6ab6709da6a933d8.jpg?submitted=1684671188405\u0026host=wbd-images.prod-vod.h264.io\u0026partner=beamcom\u0026w=500","idref8":"Rocknrolla","idref9":"{\r\n\"@context\": \"ht