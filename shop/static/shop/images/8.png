.classList.contains('hide'));\\r\\n\\r\\n          const scrollPosition = window.scrollY || window.pageYOffset;\\r\\n          const navStickyPos = window.innerHeight * 0.9;\\r\\n\\r\\n          // Add hidden class to main header nav\\r\\n          if (window.innerWidth \u003e 1024 \u0026\u0026 scrollNav \u0026\u0026 scrollPosition \u003e navStickyPos) {\\r\\n            headerNav.classList.add('hidden');\\r\\n          } else if (scrollNav \u0026\u0026 scrollPosition \u003e window.innerHeight) {\\r\\n            headerNav.classList.add('hidden');\\r\\n          } else {\\r\\n            headerNav.classList.remove('hidden');\\r\\n          }\\r\\n\\r\\n          // Add visible class to sign up cta\\r\\n          signupBtns.forEach((btn) =\u003e {\\r\\n            if (window.innerWidth \u003e 1024 \u0026\u0026 !btn.classList.contains('hide') \u0026\u0026 scrollPosition \u003e navStickyPos) {\\r\\n              btn.classList.add('visible');\\r\\n            } else if (!btn.classList.contains('hide') \u0026\u0026 scrollPosition \u003e window.innerHeight) {\\r\\n              btn.classList.add('visible');\\r\\n            } else {\\r\\n              btn.classList.remove('visible');\\r\\n            }\\r\\n          });\\r\\n        });\\r\\n      });\\r\\n    \u003c/script\u003e\",\"type\":\"string\",\"cmsType\":\"textarea\",\"mappingId\":\"idref44\"},{\"value\":\"Sign Up Now\",\"type\":\"string\",\"cmsType\":\"textfield\",\"mappingId\":\"idref45\"},{\"value\":\"Stream Now\",\"type\":\"string\",\"cmsType\":\"textfield\",\"mappingId\":\"idref46\"},{\"value\":\"https://auth.hbomax.com/product\",\"type\":\"string\",\"cmsType\":\"url\",\"mappingId\":\"idref47\"},{\"value\":\"/streamnow\",\"type\":\"string\",\"cmsType\":\"url\",\"mappingId\":\"idref48\"},{\"value\":\"You May Also Like\",\"type\":\"string\",\"cmsType\":\"textfield\",\"mappingId\":\"idref49\"},{\"value\":\"[{\\\"hbomaxId\\\":\\\"d101309f-b2d5-4fae-bf57-49b4e739ba68\\\",\\\"type\\\":\\\"feature\\\",\\\"title\\\