            */\r\n/**********************************************/\r\n\r\n#hbomax-sports-add-on-info-modal {\r\n  background-color: rgba(0, 0, 0, 0.3);\r\n  backdrop-filter: blur(0.5em);\r\n}\r\n\r\n#hbomax-sports-add-on-info-modal .modal-header img {\r\n  border-top-left-radius: calc(.25rem - 1px);\r\n  border-top-right-radius: calc(.25rem - 1px);\r\n}\r\n\r\n#hbomax-sports-add-on-info-modal .modal-header img+.close {\r\n  margin: 0;\r\n  position: absolute;\r\n  right: 0;\r\n}\r\n\r\n#hbomax-sports-add-on-info-modal .modal-content {\r\n  container-type: inline-size;\r\n}\r\n\r\n#hbomax-sports-add-on-info-modal h3 {\r\n  font-size: 1.5rem;\r\n  margin: 0rem;\r\n}\r\n#hbomax-sports-add-on-info-modal p {\r\n  font-size: .9rem;\r\n  margin: 1rem 0rem;\r\n}\r\n#hbomax-sports-add-on-info-modal p.disclaimers {\r\n  line-height: .9rem;\r\n}\r\n#hbomax-sports-add-on-info-modal ul\u003eli\u003ep {\r\n  font-size: .9rem;\r\n  margin: 0rem;\r\n}\r\n#hbomax-sports-add-on-info-modal h4 {\r\n  font-size: 1.2rem;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n#hbomax-sports-add-on-info-modal .sports-logos-proportional {\r\n    --sports-logo-max-height: 50cqi;\r\n    display: flex;\r\n    gap: 2.5rem;\r\n    align-items: center;\r\n    justify-content: center;\r\n    margin: 1rem 0rem 0rem 0rem;\r\n    flex-wrap: wrap;\r\n}\r\n\r\n.sports-logos-proportional #sports-logo-1 {\r\n    height: calc(var(--sports-logo-max-height) * var(--sports-logo-1-scale) * var(--extra-resize));\r\n    width: auto;\r\n}\r\n.sports-logos-proportional #sports-logo-2 {\r\n    height: calc(var(--sports-logo-max-height) * var(--sports-logo-2-scale) * var(--extra-resize));\r\n    width: auto;\r\n}\r\n.sports-logos-proportional #sports-logo-3 {\r\n    height:calc(var(--sports-logo-max-height) * var(--sports-logo-3-scale) * var(--extra-resize));\r\n    width: auto;\r\n}\r\n.sports-logos-proportional #sports-logo-4 {\r\n    height:calc(var(--sports-logo-max-height) * var(--sports-logo-4-scale) * var(--extra-resize));\r\n    width: auto;\r\n}\r\n\r\n/* ADJUSTMENTS FOR STRIPE IN PLAN PICKER */\r\n.max-plan-picker-group ul\u003eli a {\r\n  float: none;\r\n  color: #002be7;\r\n}\r\n/* EXTRA SPACE AFTER PLAN PICKER */\r\n.max-plan-picker-group.max-plan-picker-group-t1 {\r\n  padding-bottom: 4rem;\r\n}\r\n\r\n\u003c/style\u003e\r\n\r\n\u003cdiv id=\"hbomax-sports-add-on-info-modal\" class=\"modal fade\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"br-sports-info-modal-label\" aria-modal=\"true\"\u003e\r\n  \u003cdiv class=\"modal-dialog\" role=\"document\"\u003e\r\n    \u003cdiv class=\"modal-content bg-white border-0\"\u003e\r\n      \u003cdiv class=\"modal-header p-0\"\u003e\r\n        \u003ch5 class=\"modal-title sr-only\" id=\"br-sports-info-modal-label\"\u003eSports Add-on\u003c/h5\u003e\r\n        \u003cimg alt=\"Sports Add-on\" class=\"img img-fluid\" sizes=\"(max-width: 575px) 100vw, (min-width: 576px) and (max-width: 1024px) 100vw, (min-width: 1025px) 100vw, 100vw\" height=\"810\" width=\"1600\" data-src=\"https://beam-images.warnermediacdn.com/2025-10/int.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\u0026amp;w=480\" data-srcset=\"https://beam-images.warnermediacdn.com/2025-10/int.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\u0026amp;w=480 480w, https://beam-images.warnermediacdn.com/2025-10/int.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\u0026amp;w=960 960w, https://beam-images.warnermediacdn.com/2025-10/int.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\u0026amp;w=1200 1200w\" src=\"https://beam-images.warnermediacdn.com/2025-10/int.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\u0026amp;w=480\" srcset=\"https://beam-images.warnermediacdn.com/2025-10/int.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\u0026amp;w=480 480w, https://beam-images.warnermediacdn.com/2025-10/int.jpg?host=wbd-dotcom-drupal-prd-us-east-1.s3.amazonaws.com\u0026amp;w=960 960w, https://beam-images.warnermediacdn.com/2025-10/int